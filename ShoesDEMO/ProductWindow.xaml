<Window x:Class="ShoesDEMO.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShoesDEMO"
        mc:Ignorable="d" Style="{StaticResource Windows}"
        Title="Продукты" Height="800" Width="1200">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Grid HorizontalAlignment="Left"
              Name="AdminPanel">

            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <StackPanel Margin="20 0" Grid.Column="0">
                <TextBlock Text="Поиск"/>
                <TextBox Name="SearchingTextBox"
                         Width="200"
                         TextChanged="SearchingTextBox_TextChanged"/>
            </StackPanel>
            <StackPanel Margin="20 0" Grid.Column="1">
                <TextBlock Text="Сортировка"/>
                <ComboBox Name="SortingComboBox"
                          Width="200"
                          SelectionChanged="SotringComboBox_SelectionChanged"/>
            </StackPanel>
            <StackPanel Margin="20 0" Grid.Column="2">
                <TextBlock Text="Фильтрация"/>
                <ComboBox Name="FilteringComboBox"
                          Width="200"
                          SelectionChanged="FilteringComboBox_SelectionChanged"/>
            </StackPanel>

        </Grid>

        <TextBlock Name="FullUserName"
                   VerticalAlignment="Top"
                   HorizontalAlignment="Right"
                   Margin="20 10"/>

        <ScrollViewer Grid.Row="1">
            <ItemsControl Name="ProductList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="10"
                                Tag="{Binding Id}"
                                Background="{Binding Background}"
                                MouseDown="Border_MouseDown">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="80"
                                        Height="80"
                                        Margin="15 0">
                                    <Image Source="{Binding Photo}"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock FontWeight="SemiBold">
                                        <Run Text="{Binding Category.Name}"/>
                                        <Run Text=" | "/>
                                        <Run Text="{Binding Name}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Discription}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding ProviderId1.Name}"/>
                                    <TextBlock Text="{Binding ProducerId1.Name}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Цена: "/>
                                        <TextBlock Text="{Binding Price, StringFormat={}{0:F2} ₽}"/>
                                        <TextBlock Text="   "/>
                                        <TextBlock Text="{Binding OldPrice, StringFormat={}{0:F2} ₽}"
                                                   Foreground="Red"
                                                   TextDecorations="Strikethrough"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Unit.Name}"/>
                                    <TextBlock Text="{Binding AmountInStock}"/>
                                </StackPanel>
                                <Border Grid.Column="2">
                                    <TextBlock Text="{Binding Discount}"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button Name="LogOutButton"
                Content="Выйти"
                Grid.Row="2"
                VerticalAlignment="Center"
                HorizontalAlignment="Left"
                Margin="20 10"
                Click="LogOutButton_Click"/>

        <Button Name="CreateButton"
                Content="Создать"
                Grid.Row="2"
                VerticalAlignment="Center"
                HorizontalAlignment="Right"
                Margin="20 10"
                Visibility="Collapsed"
                Click="CreateButton_Click"/>
    </Grid>
</Window>
